# the site is published via Claude Design → Netlify.
dist/
build/
out/
export/
exports/
*.zip

# --- Dependencies (in case tooling is added later) ---
node_modules/

# --- Local environment / secrets (never commit) ---
.env
.env.*
*.pem
*.key
