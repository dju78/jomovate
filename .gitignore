ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs & temp ---
*.log
*.tmp
*.temp
tmp/
temp/

